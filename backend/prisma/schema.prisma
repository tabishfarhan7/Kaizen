// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- ENUMS ---
enum Difficulty {
  EASY
  MEDIUM
  HARD
}

enum InterviewStatus {
  STARTED
  COMPLETED
  ABANDONED
}

enum MessageSender {
  USER
  AI
}

// --- CORE MODELS ---

model User {
  id              String   @id @default(cuid())
  email           String   @unique
  passwordHash    String
  name            String
  
  // -- ONBOARDING & DASHBOARD FIELDS --
  targetRole      String   @default("Full-Stack Developer")
  targetCompanies String[] @default([])
  dreamCompany    String?  // Specifically for the new dynamic onboarding
  techStack       String[] @default([]) // Captures their primary stack
  
  // -- TRACKING PROGRESS --
  solvedMcqIds    String[] @default([]) // Array of MCQ IDs the user got correct
  solvedCodingIds String[] @default([]) // Array of Coding Challenge IDs passed
  
  // -- RELATIONSHIPS --
  interviews      MockInterview[]
  savedQuestions  SavedQuestion[]
  savedMCQs       SavedMCQ[]
  activityLogs    ActivityLog[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Company {
  id               String            @id @default(cuid())
  name             String            @unique
  logoUrl          String?        
  
  // The Relationships
  mcqs             McqQuestion[] 
  codingChallenges CodingChallenge[]
  
  createdAt        DateTime          @default(now())
}

model McqQuestion {
  id            String      @id @default(cuid())
  questionText  String      @unique
  options       String[]   
  correctAnswer String     
  difficulty    Difficulty  @default(MEDIUM)
  explanation   String?    
  
  companies     Company[]  
  savedBy       SavedMCQ[] // Links to the users who saved this MCQ
  
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model CodingChallenge {
  id          String        @id @default(cuid())
  title       String        @unique
  description String
  difficulty  Difficulty    @default(MEDIUM) 
  tags        String[]      @default([])
  starterCode String
  testCases   Json
  timeLimitMs Int           @default(2000)
  
  companies   Company[]  
  savedBy     SavedQuestion[] // Links to the users who saved this Challenge
  
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

// --- RESTRUCTURED LIVE INTERVIEW TRACKING ---

model MockInterview {
  id           String             @id @default(cuid())
  userId       String
  user         User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  role         String             // e.g., "Frontend Developer", "System Design"
  status       InterviewStatus    @default(STARTED)
  score        Int?               // AI graded overall performance score out of 100
  feedback     String?            // AI's final detailed review summary
  
  // Granular relationship for chronological streaming message history
  messages     InterviewMessage[]
  
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
}

model InterviewMessage {
  id              String        @id @default(cuid())
  interviewId     String
  interview       MockInterview @relation(fields: [interviewId], references: [id], onDelete: Cascade)
  
  sender          MessageSender // USER or AI
  text            String        @db.Text // Allows long responses and complex text sequences
  
  // Granular analytics fields for per-question grading
  questionScore   Int?          // Optional: AI score for this exact user answer (0-100)
  questionFeedback String?      // Optional: AI specific advice for this exact answer
  
  createdAt       DateTime      @default(now())
}

// --- DSA NOTES VAULT MODELS ---

model DsaTopic {
  id        String    @id @default(cuid())
  name      String    @unique // e.g., "Trees", "Dynamic Programming"
  
  // A topic can have many notes inside it
  notes     DsaNote[] 
  
  createdAt DateTime  @default(now())
}

model DsaNote {
  id        String   @id @default(cuid())
  title     String
  content   String   @db.Text // We use @db.Text so PostgreSQL allows massive markdown strings
  
  // The specific topic this note belongs to
  topicId   String
  topic     DsaTopic @relation(fields: [topicId], references: [id], onDelete: Cascade)
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// --- THE SAVED VAULT ---

model SavedQuestion {
  id         String          @id @default(cuid())
  userId     String
  questionId String   
  
  user       User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  question   CodingChallenge @relation(fields: [questionId], references: [id], onDelete: Cascade)
  savedAt    DateTime        @default(now())

  @@unique([userId, questionId]) // Prevents saving the same challenge twice
}

model SavedMCQ {
  id        String      @id @default(cuid())
  userId    String
  mcqId     String   
  
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  mcq       McqQuestion @relation(fields: [mcqId], references: [id], onDelete: Cascade)
  savedAt   DateTime    @default(now())

  @@unique([userId, mcqId]) // Prevents saving the same MCQ twice
}

// --- THE ACTIVITY HEATMAP ---

model ActivityLog {
  id        String   @id @default(cuid())
  userId    String
  action    String   // e.g., "LOGIN", "INTERVIEW_COMPLETED", "PRACTICE_COMPLETED"
  
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}